{
  "$schema": "https://schema.tauri.app/config/1",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devPath": "http://localhost:5173",
    "distDir": "../dist"
  },
  "package": {
    "productName": "KUKU-IO LED",
    "version": "0.0.0"
  },
  "tauri": {
    "allowlist": {
      "all": false
    },
    "bundle": {
      "active": true,
      "identifier": "com.kukuio.led",
      "icon": [
        "icons/icon.ico",
        "icons/icon.png"
      ],
      "targets": "all"
    },
    "security": {
      "csp": "default-src 'self'; connect-src 'self' http://localhost:5200 https://*.supabase.co https://ndlgbkugcysicbcxybyy.supabase.co; img-src 'self' data: https:; script-src 'self'; style-src 'self' 'unsafe-inline'; font-src 'self';"
    },
    "windows": [
      {
        "title": "KUKU-IO LED",
        "width": 1280,
        "height": 820,
        "resizable": true,
        "fullscreen": false,
        "maximized": true,
        "decorations": true
      }
    ]
  }
}
